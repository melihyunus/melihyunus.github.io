<title>Küp</title>
<link rel="stylesheet" type="text/css" href="/css/cube.css">
<div class="container">
    <div class="cube-container">
        <div class="parameters">
            <div class="title">Left</div>
            <div class="title">Right</div>
            <div class="title">RotateX</div>
            <div class="title">RotateY</div>
            <input id="X" type="number" size="3"/>
            <input id="Y" type="number" size="3"/>
            <input id="rX" type="number" size="3"/>
            <input id="rY" type="number" size="3"/>
        </div>
        <div class="cube-base">
            <div class="move"><img src="/images/move.svg" width="32"/></div>
            <div class="cube" draggable="false">
                <div class="side front"><img src="/images/c-2.svg"></div>
                <div class="side back"><img src="/images/net.svg"></div>
                <div class="side left"><img src="/images/node.svg"></div>
                <div class="side right"><img src="/images/c-1.svg"></div>
                <div class="side top"><img src="/images/sql.svg"></div>
                <div class="side bottom"><img src="/images/html.svg"></div>
            </div>
        </div>        
    </div>
</div>

<script src="/js/cube.js"></script>